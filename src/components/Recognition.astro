---
import { recognition } from '../data/content';
---

<section id="recognition" class="section section--alt" aria-labelledby="recognition-heading">
  <div class="container">
    <header class="rec-head" data-reveal>
      <span class="kicker">Recognition</span>
      <h2 id="recognition-heading">Notable milestones</h2>
    </header>

    <ul class="rec-grid" role="list">
      {recognition.map((item) => (
        <li class="rec-card" data-reveal>
          {item.year && <span class="rec-year">{item.year}</span>}
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .rec-head { margin-bottom: var(--space-xl); }
  .rec-head h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-xs);
  }

  .rec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(290px, 100%), 1fr));
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Single hairline border on a lighter fill — subtle lift, no ghost-card */
  .rec-card {
    padding: var(--space-md);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 12px;
  }
  .rec-year {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent-deep);
    margin-bottom: 0.5rem;
  }
  .rec-card h3 {
    font-size: var(--text-md);
    margin-bottom: 0.4rem;
  }
  .rec-card p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: 1.6;
  }
</style>
