---
import { recognition } from '../data/content';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section id="recognition" class="section section--alt rec-section" aria-labelledby="recognition-heading">
  <div class="rec-bg" aria-hidden="true" id="rec-bg"></div>
  <div class="container">
    <header class="rec-head" data-reveal>
      <span class="kicker">Recognition</span>
      <h2 id="recognition-heading">Notable milestones</h2>
    </header>

    <div class="deck-scene" data-reveal>
      <!--
        role="button" on the deck makes the whole stack one focusable target.
        Individual cards are aria-hidden except the front one; the aria-live
        region announces what's showing after each advance.
      -->
      <div
        class="deck"
        id="rec-deck"
        role="button"
        tabindex="0"
        aria-label="Recognition milestone cards — click or press Enter to advance"
      >
        {recognition.map((item, i) => (
          <article
            class={`card${item.image ? ' card--has-image' : ''}`}
            data-pos={i <= 3 ? String(i) : 'hidden'}
            aria-hidden={i === 0 ? 'false' : 'true'}
          >
            <div class="card-photo">
              {item.image
                ? <img src={`${base}${item.image}`} alt="" loading="lazy" />
                : <span class="card-num" aria-hidden="true">
                    {String(i + 1).padStart(2, '0')}
                  </span>
              }
            </div>
            <div class="card-content">
              {item.year && <span class="card-year">{item.year}</span>}
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="deck-footer">
        <span class="deck-counter" id="rec-counter">1 / {recognition.length}</span>
        <span class="deck-hint" aria-hidden="true">— click to advance</span>
      </div>
      <!-- screen-reader live region -->
      <p class="visually-hidden" aria-live="polite" id="rec-live"></p>
    </div>
  </div>
</section>

<style>
  .rec-section { overflow: hidden; position: relative; }

  .rec-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: center top;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .rec-section > .container {
    position: relative;
    z-index: 1;
  }
  .rec-head { margin-bottom: var(--space-xl); }
  .rec-head h2 { margin-top: var(--space-xs); }

  /* Extra padding so rotated behind-cards don't get clipped */
  .deck-scene {
    width: min(760px, 100%);
    margin: 0 auto;
    padding: 28px 22px 0;
  }

  /* Grid-stack: all cards in cell 1/1 so height is driven by card content */
  .deck {
    display: grid;
    cursor: pointer;
    border-radius: 18px;
  }
  .deck:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 8px;
    border-radius: 20px;
  }

  .card {
    grid-area: 1 / 1;
    background: var(--paper);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 6px 28px rgba(26, 20, 16, 0.14);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity   0.35s ease;
    will-change: transform;
    user-select: none;
  }

  /* ── Stack positions ── */
  .card[data-pos="0"] {
    transform: none;
    z-index: 10;
    /* Spring overshoot: card "pops" into place when it becomes the new front */
    transition: transform 0.5s cubic-bezier(0.34, 1.45, 0.64, 1),
                opacity   0.35s ease;
  }
  .deck:hover .card[data-pos="0"] {
    transform: translateY(-4px);
  }
  .card[data-pos="1"] {
    transform: rotate(4deg) translate(14px, 6px);
    z-index: 9;
    transition-delay: 0ms;
  }
  .card[data-pos="2"] {
    transform: rotate(-3deg) translate(-12px, 12px);
    z-index: 8;
    opacity: 0.85;
    transition-delay: 30ms;
  }
  .card[data-pos="3"] {
    transform: rotate(1.5deg) translate(5px, 18px);
    z-index: 7;
    opacity: 0.65;
    transition-delay: 60ms;
  }
  .card[data-pos="hidden"] {
    transform: translate(0, 15px);
    z-index: 1;
    opacity: 0;
    pointer-events: none;
  }

  /* ── Exit animation: fly off to the right ── */
  @keyframes card-exit {
    from { transform: none; opacity: 1; }
    to   { transform: translateX(115%) rotate(12deg); opacity: 0; }
  }
  .card.exiting {
    animation: card-exit 0.38s cubic-bezier(0.4, 0, 0.85, 1) forwards;
    z-index: 20;
    pointer-events: none;
  }

  /* ── Photo area ── */
  .card-photo {
    width: 100%;
    height: 210px;
    background: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }
  .card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* ── Full-bleed image cards ── */
  .card--has-image {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 340px;
  }
  .card--has-image .card-photo {
    position: absolute;
    inset: 0;
    height: auto;
    z-index: 0;
  }
  /* Gradient fade: image visible at top, darkens toward bottom for text legibility */
  .card--has-image .card-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 25%, rgba(10, 8, 6, 0.93) 75%);
    z-index: 1;
  }
  .card--has-image .card-content {
    position: relative;
    z-index: 2;
  }
  .card--has-image .card-year { color: var(--accent); }
  .card--has-image .card-content h3 { color: var(--paper); }
  .card--has-image .card-content p { color: rgba(255, 255, 255, 0.7); }

  /* Placeholder numeral — editorial, signals photo slot */
  .card-num {
    font-family: var(--font-display);
    font-size: 5.5rem;
    line-height: 1;
    color: var(--paper-soft);
    opacity: 0.28;
    pointer-events: none;
  }

  /* ── Card content ── */
  .card-content { padding: var(--space-md); }
  .card-year {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent-deep);
    margin-bottom: 0.35rem;
  }
  .card-content h3 {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.4rem;
  }
  .card-content p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: none;
  }

  /* ── Counter + hint ── */
  .deck-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-xl);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }
  .deck-counter {
    font-weight: 600;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }

  @media (min-width: 860px) {
    .deck-scene { padding: 36px 30px 0; }
    .card-photo { height: clamp(260px, 24vw, 360px); }
    .card--has-image { min-height: 480px; }
    .card-num { font-size: 8rem; }
    .card-content { padding: var(--space-lg); }
    .card-content h3 { font-size: var(--text-lg); margin-bottom: 0.6rem; }
    .card-content p { font-size: var(--text-base); }
  }

  @media (max-width: 520px) {
    .deck-scene { padding: 20px 14px 0; }
    .card-photo { height: 240px; }
    .card-content { padding: var(--space-lg) var(--space-md); }
    .card-num { font-size: 4.5rem; }
  }
</style>

<script>
  const deck    = document.getElementById('rec-deck') as HTMLElement | null;
  const counter = document.getElementById('rec-counter') as HTMLElement | null;
  const live    = document.getElementById('rec-live')    as HTMLElement | null;
  if (!deck) throw new Error('rec-deck not found');

  const cards  = [...deck.querySelectorAll<HTMLElement>('.card')];
  const total  = cards.length;
  const order  = cards.map((_, i) => i); // rotation queue: front is order[0]
  let step      = 0;
  let animating = false;
  const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function applyPositions() {
    order.forEach((cardIdx, pos) => {
      const card = cards[cardIdx];
      card.setAttribute('data-pos', pos <= 3 ? String(pos) : 'hidden');
      card.setAttribute('aria-hidden', pos === 0 ? 'false' : 'true');
    });
  }

  const recBg = document.getElementById('rec-bg') as HTMLElement | null;

  function updateMeta() {
    if (counter) counter.textContent = `${step + 1} / ${total}`;
    const front = cards[order[0]];
    const title = front.querySelector('h3')?.textContent ?? '';
    const year  = front.querySelector('.card-year')?.textContent ?? '';
    if (live) live.textContent = `Now showing: ${title}${year ? `, ${year}` : ''}`;

    if (recBg) {
      const cardImg = front.querySelector<HTMLImageElement>('.card-photo img');
      if (cardImg?.src) {
        recBg.style.backgroundImage = `url(${cardImg.src})`;
        recBg.style.opacity = '0.1';
      } else {
        recBg.style.opacity = '0';
      }
    }
  }

  updateMeta(); // set bg for initial front card

  function advance() {
    if (animating) return;
    animating = true;

    // Reduced motion: instant swap, no animation
    if (noMotion) {
      order.push(order.shift()!);
      step = (step + 1) % total;
      applyPositions();
      updateMeta();
      animating = false;
      return;
    }

    const front = cards[order[0]];
    front.classList.add('exiting');

    // Shuffle back cards while front card is mid-flight (not after it lands).
    // This makes the whole deck feel like one cohesive motion.
    setTimeout(() => {
      order.push(order.shift()!);
      step = (step + 1) % total;
      applyPositions();
      updateMeta();
    }, 80);

    // Clean up exiting card after the animation finishes
    setTimeout(() => {
      front.classList.remove('exiting');
      animating = false;
    }, 460);
  }

  deck.addEventListener('click', advance);
  deck.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); advance(); }
  });
</script>
