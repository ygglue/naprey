---
import { recognition } from '../data/content';
---

<section id="recognition" class="section section--alt" aria-labelledby="recognition-heading">
  <div class="container container--narrow">
    <header class="rec-head" data-reveal>
      <span class="kicker">Recognition</span>
      <h2 id="recognition-heading">{recognition.heading}</h2>
    </header>

    <p class="rec-running" data-reveal>{recognition.body}</p>
  </div>
</section>

<style>
  .rec-head { margin-bottom: var(--space-lg); }
  .rec-head h2 { margin-top: var(--space-xs); }

  .rec-running {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1.45;
    color: var(--ink);
    max-width: none;
  }
</style>
