---
import { work, services } from '../data/content';
---

<section id="work" class="section section--alt" aria-labelledby="work-heading">
  <div class="container">
    <header class="svc-head" data-reveal>
      <span class="kicker">{services.kicker}</span>
      <h2 id="work-heading">{services.heading}</h2>
      <p class="svc-intro">{services.intro}</p>
    </header>

    <ol class="svc-list" role="list">
      {work.map((item, i) => (
        <li class="svc-item" data-reveal>
          <span class="svc-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div class="svc-main">
            <div class="svc-titleline">
              <h3>{item.name}</h3>
              {item.highlight && <span class="svc-tag">{item.highlight}</span>}
            </div>
            <p class="svc-role">{item.role} · {item.period}</p>
            <p class="svc-desc">{item.description}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="svc-cta" data-reveal>
      <a href={services.cta.href} class="btn btn-primary">{services.cta.label}</a>
    </div>
  </div>
</section>

<style>
  .svc-head { margin-bottom: var(--space-xl); max-width: 60ch; }
  .svc-head h2 {
    font-size: var(--text-2xl);
    margin-block: var(--space-xs) var(--space-md);
  }
  .svc-intro {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .svc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .svc-item {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: clamp(1rem, 0.5rem + 2vw, 2.5rem);
    padding-block: var(--space-lg);
    border-bottom: 1px solid var(--line);
  }

  .svc-num {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1;
    color: var(--accent);
  }

  .svc-titleline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 0.85rem;
    margin-bottom: 0.3rem;
  }
  .svc-titleline h3 { font-size: var(--text-lg); }

  .svc-tag {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent-deep);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border-radius: 100px;
  }

  .svc-role {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink-soft);
    margin-bottom: 0.5rem;
    max-width: none;
  }
  .svc-desc { color: var(--ink-soft); }

  .svc-cta { margin-top: var(--space-xl); }

  @media (max-width: 540px) {
    .svc-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .svc-num { font-size: var(--text-lg); }
    .svc-cta .btn { width: 100%; }
  }
</style>
