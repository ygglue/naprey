---
import { affiliations } from '../data/content';
---

<section id="affiliations" class="section section--alt" aria-labelledby="affiliations-heading">
  <div class="container">
    <header class="aff-head" data-reveal>
      <span class="kicker">Community</span>
      <h2 id="affiliations-heading">Affiliations</h2>
    </header>

    <ul class="aff-list" role="list" data-reveal>
      {affiliations.map((item) => (
        <li class="aff-item">{item}</li>
      ))}
    </ul>
  </div>
</section>

<style>
  .aff-head { margin-bottom: var(--space-lg); }
  .aff-head h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-xs);
  }

  .aff-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(360px, 100%), 1fr));
    gap: 0 var(--space-xl);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .aff-item {
    font-size: var(--text-base);
    color: var(--ink);
    padding-block: 0.85rem;
    border-bottom: 1px solid var(--line);
  }
</style>
