---
import { footer, contact } from '../data/content';
---

<footer class="site-footer" role="contentinfo">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="footer-name">{footer.name}</p>
      <p class="footer-tagline">{footer.tagline}</p>
    </div>

    <nav class="footer-social" aria-label="Social media links">
      <ul role="list">
        {contact.social.map((s) => (
          <li>
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${s.platform}: ${s.label} (opens in new tab)`}
            >{s.platform}</a>
          </li>
        ))}
      </ul>
    </nav>

    <p class="footer-copy">{footer.copy}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--paper-soft);
    padding-block: var(--space-xl);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: var(--space-md);
    align-items: center;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--paper);
    margin-bottom: 0.1rem;
    max-width: none;
  }
  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--paper-soft);
    max-width: none;
  }

  .footer-social ul {
    display: flex;
    gap: var(--space-md);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-social a {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--paper);
    text-decoration: none;
  }
  .footer-social a:hover { color: var(--accent); }

  .footer-copy {
    grid-column: 1 / -1;
    font-size: var(--text-sm);
    color: var(--paper-soft);
    max-width: none;
    padding-top: var(--space-md);
    border-top: 1px solid var(--line-ink);
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-social ul { justify-content: center; gap: var(--space-md); }
  }
</style>
