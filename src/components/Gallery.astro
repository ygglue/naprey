---
import { gallery } from '../data/content';
import { ChevronLeft, ChevronRight, ArrowDown } from 'lucide-astro';
---

<section id="gallery" class="section" aria-labelledby="gallery-heading">
  <div class="container">
    <header class="gal-head" data-reveal>
      <span class="kicker">{gallery.kicker}</span>
      <h2 id="gallery-heading">{gallery.heading}</h2>
      <p class="gal-intro">{gallery.intro}</p>
    </header>

    <div class="gal-pin">
      <div class="gal-pin-inner">
        {gallery.categories.map((category) => (
          <div class="gal-category" data-reveal>
            <div class="gal-cat-head">
              <button type="button" class="gal-nav gal-prev" aria-label="Previous category">
                <ChevronLeft aria-hidden="true" />
              </button>
              <h3>{category.name}</h3>
              <button type="button" class="gal-nav gal-next" aria-label="Next category">
                <ChevronRight aria-hidden="true" />
              </button>
            </div>
            <ul class="gal-strip" role="list">
              {category.items.map((item) => (
                <li class="gal-item" tabindex="0" aria-label={item.alt}>
                  {item.src
                    ? <img src={item.src} alt={item.alt} loading="lazy" />
                    : <div class="gal-placeholder" aria-hidden="true" />
                  }
                </li>
              ))}
            </ul>
          </div>
        ))}

        <a href="#partnerships" class="gal-skip">
          Skip gallery
          <ArrowDown class="gal-skip-arrow" aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>
</section>

<dialog class="gal-lightbox" id="gal-lightbox" aria-label="Photo viewer">
  <button class="gal-lb-close" aria-label="Close photo viewer">&#x2715;</button>
  <img class="gal-lb-img" src="" alt="" />
</dialog>

<style>
  .gal-head { margin-bottom: var(--space-xl); max-width: 60ch; }
  .gal-head h2 { margin-block: var(--space-xs) var(--space-md); }
  .gal-intro {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .gal-category { margin-top: var(--space-xl); }
  .gal-category:first-of-type { margin-top: 0; }
  .gal-category h3 { margin-bottom: var(--space-sm); }

  /* Category prev/next controls — mobile only (hidden on desktop) */
  .gal-nav { display: none; }

  /* Pin wrappers are inert on desktop; skip button is mobile-only */
  .gal-pin,
  .gal-pin-inner { display: contents; }
  .gal-skip { display: none; }

  /* ── Expand-on-hover strip ── */
  .gal-strip {
    display: flex;
    gap: 0.5rem;
    height: clamp(180px, 30vw, 440px);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .gal-item {
    flex: 1;
    overflow: hidden;
    border-radius: 10px;
    position: relative;
    cursor: pointer;
    outline: none;
    transition: flex 0.45s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
  }

  /* Shrink non-active siblings */
  .gal-strip:has(.gal-item:hover) .gal-item,
  .gal-strip:has(.gal-item:focus-visible) .gal-item,
  .gal-strip:has(.gal-item.is-active) .gal-item { flex: 0.3; }

  /* Expand the active item */
  .gal-strip:has(.gal-item:hover) .gal-item:hover,
  .gal-strip:has(.gal-item:focus-visible) .gal-item:focus-visible,
  .gal-strip:has(.gal-item.is-active) .gal-item.is-active { flex: 3; }

  .gal-item:focus-visible { box-shadow: 0 0 0 3px var(--accent); }

  .gal-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .gal-placeholder {
    width: 100%;
    height: 100%;
    background: var(--paper-2);
    border: 1px dashed var(--line);
  }

  .gal-label {
    position: absolute;
    bottom: 0.6rem;
    left: 0.75rem;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }
  .gal-item:hover .gal-label,
  .gal-item:focus-visible .gal-label,
  .gal-item.is-active .gal-label { opacity: 1; transform: none; }

  /* Label on real photo — white with shadow for legibility */
  .gal-item:has(img) .gal-label {
    color: var(--paper);
    text-shadow: 0 1px 4px rgba(26, 20, 16, 0.5);
  }

  /* ── Mobile: pinned, scroll drives the active image ── */
  @media (max-width: 599px) {
    /* Runway — its height is the scroll distance that steps through images */
    .gal-pin {
      display: block;
      position: relative;
      height: 320vh;
    }
    /* Pinned viewport that stays on screen while scrolling the runway */
    .gal-pin-inner {
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      height: 100dvh;
      padding-block: var(--space-lg);
    }

    /* Show only the current category; buttons cycle between them */
    .gal-category { display: none; margin-top: 0; }
    .gal-category.is-current {
      display: flex;
      flex-direction: column;
      justify-content: center;
      flex: 1;
      min-height: 0;
    }

    .gal-cat-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-sm);
      margin-bottom: var(--space-md);
    }
    .gal-cat-head h3 { margin: 0; text-align: center; }

    .gal-nav {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: none;
      width: 44px;
      height: 44px;
      border: 1px solid var(--line);
      border-radius: 50%;
      background: var(--paper);
      color: var(--ink);
      cursor: pointer;
    }
    .gal-nav :global(svg) {
      width: 22px;
      height: 22px;
      display: block;
    }
    .gal-nav:active { background: var(--paper-2); }
    .gal-nav:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* Vertical accordion — active image (driven by scroll) expands */
    .gal-strip {
      flex-direction: column;
      height: auto;
      flex: 1;
      min-height: 0;
      gap: 0.5rem;
    }
    .gal-item { aspect-ratio: unset; }
    .gal-item:not(.is-active) { pointer-events: none; }

    /* Bouncing skip control */
    .gal-skip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      align-self: center;
      margin-top: var(--space-md);
      padding: 0.6rem 1.1rem;
      border-radius: 999px;
      background: var(--ink);
      color: var(--paper);
      font-size: var(--text-sm);
      font-weight: 700;
      text-decoration: none;
      animation: gal-bounce 1.4s ease-in-out infinite;
    }
    .gal-skip :global(svg) {
      width: 1.05em;
      height: 1.05em;
      display: block;
    }
    .gal-skip:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    @keyframes gal-bounce {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(5px); }
    }
  }

  /* Reduced motion: unpin, no scroll-jack, no bounce — plain accordion + buttons */
  @media (max-width: 599px) and (prefers-reduced-motion: reduce) {
    .gal-pin { height: auto; }
    .gal-pin-inner {
      display: block;
      position: static;
      height: auto;
      padding-block: 0;
    }
    .gal-category.is-current { display: block; }
    .gal-strip { height: clamp(400px, 70vh, 620px); flex: none; }
    .gal-skip { animation: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gal-item { transition: none; }
    .gal-label { transition: none; }
  }

  /* ── Lightbox ── */
  .gal-lightbox {
    border: none;
    background: transparent;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gal-lightbox::backdrop {
    background: rgba(26, 20, 16, 0.92);
  }
  .gal-lb-img {
    max-width: min(92vw, 1200px);
    max-height: 88vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
    display: block;
  }
  .gal-lb-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.1);
    color: #fff;
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gal-lb-close:hover { background: rgba(255,255,255,0.2); }
  .gal-lb-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>

<script>
  const cats = Array.from(document.querySelectorAll('.gal-category'));
  const pin = document.querySelector<HTMLElement>('.gal-pin');
  const mqMobile = window.matchMedia('(max-width: 599px)');

  // Lightbox
  const lb = document.querySelector<HTMLDialogElement>('#gal-lightbox');
  const lbImg = lb?.querySelector<HTMLImageElement>('.gal-lb-img');
  const lbClose = lb?.querySelector<HTMLButtonElement>('.gal-lb-close');

  const openLightbox = (src: string, alt: string) => {
    if (!lb || !lbImg || !src) return;
    lbImg.src = src;
    lbImg.alt = alt;
    lb.showModal();
  };
  const closeLightbox = () => lb?.close();

  lbClose?.addEventListener('click', closeLightbox);
  lb?.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && lb?.open) closeLightbox(); });

  // Desktop: hover expands + click opens lightbox for that item
  // Mobile: click opens lightbox for the currently active item (scroll-driven)
  document.querySelectorAll('.gal-strip').forEach(strip => {
    strip.querySelectorAll('.gal-item').forEach(item => {
      const activate = () => {
        strip.querySelectorAll('.gal-item').forEach(i => i.classList.remove('is-active'));
        item.classList.add('is-active');
      };
      item.addEventListener('mouseenter', activate);
      item.addEventListener('click', () => {
        if (mqMobile.matches) {
          if (!item.classList.contains('is-active')) return;
          const img = cats[current]?.querySelector<HTMLImageElement>('.gal-item.is-active img');
          if (img) openLightbox(img.src, img.alt);
        } else {
          activate();
          const img = item.querySelector<HTMLImageElement>('img');
          if (img) openLightbox(img.src, img.alt);
        }
      });
    });
  });
  const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');

  let current = 0;
  const showCategory = (i: number) => {
    current = (i + cats.length) % cats.length;
    cats.forEach((c, idx) => c.classList.toggle('is-current', idx === current));
    // Hide boundary nav buttons (visibility:hidden keeps layout stable)
    cats.forEach((c, idx) => {
      const prev = c.querySelector<HTMLButtonElement>('.gal-prev');
      const next = c.querySelector<HTMLButtonElement>('.gal-next');
      if (prev) prev.style.visibility = idx === 0 ? 'hidden' : '';
      if (next) next.style.visibility = idx === cats.length - 1 ? 'hidden' : '';
    });
  };

  // Fade items by distance from active — further away = more transparent
  const updateOpacity = () => {
    if (!mqMobile.matches) return;
    const items = Array.from(cats[current]?.querySelectorAll<HTMLElement>('.gal-item') ?? []);
    const activeIdx = items.findIndex(el => el.classList.contains('is-active'));
    if (activeIdx === -1) return;
    items.forEach((el, i) => {
      const dist = Math.abs(i - activeIdx);
      el.style.opacity = dist === 0 ? '' : String(Math.max(0.2, 1 - dist * 0.2));
    });
  };

  // Mobile only: map scroll progress through the pinned runway to the active image
  const syncActive = () => {
    if (!pin || !mqMobile.matches || mqReduce.matches) return;
    const items = cats[current].querySelectorAll('.gal-item');
    if (!items.length) return;
    const runway = pin.offsetHeight - window.innerHeight;
    const scrolled = Math.min(Math.max(-pin.getBoundingClientRect().top, 0), runway);
    const progress = runway > 0 ? scrolled / runway : 0;
    const idx = Math.min(items.length - 1, Math.round(progress * (items.length - 1)));
    items.forEach((it, i) => it.classList.toggle('is-active', i === idx));
    updateOpacity();
  };

  // Toggle a flag on <html> while the gallery is pinned so the sticky nav can
  // slide away (CSS in global.css) — keeps the ‹ › category controls tappable.
  const onScroll = () => {
    if (pin) {
      const rect = pin.getBoundingClientRect();
      const pinned = mqMobile.matches && !mqReduce.matches &&
        rect.top <= 0 && rect.bottom >= window.innerHeight;
      document.documentElement.classList.toggle('gallery-pinned', pinned);
    }
    syncActive();
  };

  if (cats.length) {
    cats.forEach(cat => {
      cat.querySelector('.gal-prev')?.addEventListener('click', () => { showCategory(current - 1); syncActive(); updateOpacity(); });
      cat.querySelector('.gal-next')?.addEventListener('click', () => { showCategory(current + 1); syncActive(); updateOpacity(); });
    });
    showCategory(0);
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    onScroll();
  }
</script>
