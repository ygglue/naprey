---
import { hero } from '../data/content';
---

<section class="hero" aria-labelledby="hero-name">
  <div class="hero-inner container">
    <p class="hero-eyebrow" data-reveal>
      <span>{hero.title}</span>
      <span class="hero-dot" aria-hidden="true">·</span>
      <span>{hero.location}</span>
    </p>

    <h1 id="hero-name" class="hero-name" data-reveal>
      Naprey<span class="hero-name-2">Almario</span>
    </h1>

    <p class="hero-tagline" data-reveal>{hero.tagline}</p>

    <p class="hero-intro" data-reveal>{hero.intro}</p>

    <div class="hero-ctas" data-reveal>
      <a href={hero.cta.href} class="btn btn-primary">{hero.cta.label}</a>
      <a href={hero.secondaryCta.href} class="btn btn-outline">{hero.secondaryCta.label}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(3.5rem, 2rem + 9vw, 8rem);
    scroll-margin-top: var(--nav-h);
    overflow: hidden;
  }

  .hero-eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--ink-soft);
    max-width: none;
    margin-bottom: var(--space-md);
  }
  .hero-dot { color: var(--accent); }

  .hero-name {
    font-size: clamp(2.8rem, 1rem + 11vw, 6.2rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
  }
  .hero-name-2 {
    display: block;
    color: var(--accent);
  }

  .hero-tagline {
    position: relative;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-2xl);
    line-height: 1.18;
    color: var(--ink);
    max-width: 24ch;
    margin-bottom: var(--space-lg);
    padding-left: clamp(2rem, 1rem + 3vw, 3.5rem);
  }
  /* Oversized hanging quotation mark — replaces the old left-stripe border */
  .hero-tagline::before {
    content: '\201C';
    position: absolute;
    left: -0.1rem;
    top: -0.35em;
    font-family: var(--font-display);
    font-style: normal;
    font-size: clamp(4rem, 2rem + 8vw, 7rem);
    line-height: 1;
    color: var(--accent);
    opacity: 0.28;
  }

  .hero-intro {
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 52ch;
    margin-bottom: var(--space-xl);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  @media (max-width: 520px) {
    .hero-ctas { flex-direction: column; align-items: stretch; }
    .hero-ctas .btn { width: 100%; }
  }
</style>
