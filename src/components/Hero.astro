---
import { hero } from '../data/content';

const roles = hero.title.split(' · ');
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section class="hero" aria-labelledby="hero-name">
  <div class="hero-inner container">
    <div class="hero-text">
      <p class="hero-eyebrow" data-reveal>
        {roles.map((role, i) => (
          <Fragment>
            {i > 0 && <span class="hero-dot" aria-hidden="true">·</span>}
            <span class="hero-role">{role}</span>
          </Fragment>
        ))}
      </p>

      <h1 id="hero-name" class="hero-name" data-reveal>
        Naprey<span class="hero-name-2">Almario</span>
      </h1>

      <p class="hero-tagline" data-reveal>{hero.tagline}</p>

      <p class="hero-intro" data-reveal>{hero.intro}</p>

      <div class="hero-ctas" data-reveal>
        <a href={hero.cta.href} class="btn btn-primary">{hero.cta.label}</a>
        <a href={hero.secondaryCta.href} class="btn btn-outline">{hero.secondaryCta.label}</a>
      </div>
    </div>

    <div class="hero-media">
      <img
        src={`${base}naprey.png`}
        alt="Naprey Almario"
        width="666"
        height="666"
        fetchpriority="high"
        data-reveal
      />
    </div>
  </div>
</section>

<style>
  .hero {
    /* Fill the screen below the sticky nav so the CTA is visible without
       scrolling. min-height (never fixed height) lets content grow & scroll
       at 200% zoom / short landscape — WCAG reflow preserved. */
    min-height: calc(100svh - var(--nav-h));
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: var(--space-lg);
    scroll-margin-top: var(--nav-h);
    overflow: hidden;
    position: relative;
  }

  /* Photo is a right-side background layer at ALL widths — it sits beside the
     hero text (never pushing it) and the text keeps a column on the left. */
  .hero-text {
    position: relative;
    z-index: 1;
    max-width: 62%;
  }
  .hero-media {
    position: absolute;
    z-index: 0;
    top: 50%;
    right: clamp(-2.5rem, -5vw, 0rem);
    transform: translateY(-50%);
    width: clamp(140px, 40vw, 300px);
    pointer-events: none;
  }
  .hero-media img {
    display: block;
    width: 100%;
    height: auto;
    /* Soft "cloudy" fade at the bottom so the shoulders dissolve into the
       page instead of a hard rectangular cut. The long gradient (45% → 95%)
       feathers gently rather than showing a crisp edge. */
    -webkit-mask-image: linear-gradient(to bottom, #000 45%, transparent 95%);
    mask-image: linear-gradient(to bottom, #000 45%, transparent 95%);
  }

  /* Desktop: larger, biased toward the center-right of the viewport */
  @media (min-width: 860px) {
    .hero-text { max-width: 36rem; }
    .hero-media {
      right: auto;
      left: 72%;
      transform: translate(-50%, -50%);
      width: clamp(460px, 50vw, 760px);
    }
  }

  .hero-eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--ink-soft);
    max-width: none;
    margin-bottom: var(--space-sm);
  }
  .hero-dot { color: var(--accent); }

  .hero-name {
    font-size: var(--text-display);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }
  .hero-name-2 {
    display: block;
    color: var(--accent);
  }

  .hero-tagline {
    position: relative;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-2xl);
    line-height: 1.18;
    color: var(--ink);
    max-width: 24ch;
    margin-bottom: var(--space-md);
    padding-left: clamp(2rem, 1rem + 3vw, 3.5rem);
  }
  /* Oversized hanging quotation mark — replaces the old left-stripe border */
  .hero-tagline::before {
    content: '\201C';
    position: absolute;
    left: -0.1rem;
    top: -0.35em;
    font-family: var(--font-display);
    font-style: normal;
    font-size: clamp(4rem, 2rem + 8vw, 7rem);
    line-height: 1;
    color: var(--accent);
    opacity: 0.28;
  }

  .hero-intro {
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 52ch;
    margin-bottom: var(--space-lg);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* Short viewports (laptops ~800px tall, landscape phones): compress the
     stack so the CTA stays on-screen. */
  @media (max-height: 760px) {
    .hero-eyebrow { margin-bottom: var(--space-sm); }
    .hero-name {
      font-size: clamp(2.2rem, 0.8rem + 7vw, 4rem);
      margin-bottom: var(--space-sm);
    }
    .hero-tagline {
      font-size: var(--text-xl);
      margin-bottom: var(--space-sm);
    }
    .hero-intro {
      font-size: var(--text-base);
      line-height: 1.45;
      margin-bottom: var(--space-md);
    }
  }

  /* Below desktop: text fills width, photo as right overlay — no in-between state */
  @media (max-width: 859px) {
    .hero-text { max-width: none; }
    .hero-media {
      top: 16%;
      right: 0;
      width: clamp(200px, 48vw, 480px);
    }
  }

  /* Phone only: compact sizing, stacked roles + CTAs */
  @media (max-width: 520px) {
    .hero-dot { display: none; }
    .hero-role { flex-basis: 100%; }
    .hero-eyebrow { margin-bottom: var(--space-md); }
    .hero-name { margin-bottom: var(--space-lg); }
    .hero-tagline {
      font-size: var(--text-xl);
      margin-bottom: var(--space-lg);
    }
    .hero-tagline::before { font-size: clamp(3.5rem, 2rem + 6vw, 5.5rem); }
    .hero-intro {
      font-size: var(--text-base);
      margin-bottom: var(--space-xl);
    }
    .hero-ctas { flex-direction: column; align-items: stretch; }
    .hero-ctas .btn { width: 100%; }
    .hero-media { width: clamp(270px, 74vw, 340px); }
  }
</style>
