---
import { advocacy } from '../data/content';
---

<section id="advocacy" class="section" aria-labelledby="advocacy-heading">
  <div class="container">
    <header class="adv-head" data-reveal>
      <span class="kicker">Purpose</span>
      <h2 id="advocacy-heading">Advocacy &amp; causes</h2>
      <p class="adv-intro">
        Disability is not inability. Through community building and direct action, Naprey champions
        the rights and visibility of Persons with Disability across the Philippines and beyond.
      </p>
    </header>

    <ul class="adv-list" role="list">
      {advocacy.map((item) => (
        <li class="adv-item" data-reveal>
          <h3>{item.name}</h3>
          <p class="adv-role">
            {item.role}{item.since ? ` · Since ${item.since}` : ''}
          </p>
          <p class="adv-desc">{item.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .adv-head { margin-bottom: var(--space-xl); max-width: 60ch; }
  .adv-head h2 {
    font-size: var(--text-2xl);
    margin-block: var(--space-xs) var(--space-md);
  }
  .adv-intro {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .adv-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
    gap: var(--space-lg) var(--space-xl);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .adv-item {
    padding-top: var(--space-md);
    border-top: 2px solid var(--ink);
  }
  .adv-item h3 {
    font-size: var(--text-lg);
    margin-bottom: 0.2rem;
  }
  .adv-role {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent-deep);
    margin-bottom: 0.6rem;
    max-width: none;
  }
  .adv-desc { color: var(--ink-soft); }
</style>
