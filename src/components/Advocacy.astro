---
import { advocacy } from '../data/content';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section id="advocacy" class="section" aria-labelledby="advocacy-heading">
  <div class="container">
    <header class="adv-head" data-reveal>
      <span class="kicker">Purpose</span>
      <h2 id="advocacy-heading">Advocacy &amp; causes</h2>
      <p class="adv-intro">
        Disability is not inability. Through community building and direct action, Naprey champions
        the rights and visibility of Persons with Disability across the Philippines and beyond.
      </p>
    </header>

    <ul class="adv-list" role="list">
      {advocacy.map((item, i) => (
        <li class="adv-item" data-reveal>
          <div class="adv-photo">
            {item.image
              ? <img src={/^https?:\/\//.test(item.image!) ? item.image : `${base}${item.image}`} alt="" loading="lazy" />
              : <span class="adv-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            }
          </div>
          <h3>{item.title}</h3>
          <p class="adv-desc">{item.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .adv-head { margin-bottom: var(--space-xl); max-width: 60ch; }
  .adv-head h2 { margin-block: var(--space-xs) var(--space-md); }
  .adv-intro {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .adv-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: var(--space-lg) var(--space-xl);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .adv-item {
    display: flex;
    flex-direction: column;
  }

  .adv-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    margin-bottom: var(--space-sm);
    background: var(--paper-2);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .adv-photo img { width: 100%; height: 100%; object-fit: cover; }
  .adv-num {
    font-family: var(--font-display);
    font-size: 3.5rem;
    color: var(--accent);
    opacity: 0.35;
  }

  .adv-item h3 { margin-bottom: 0.4rem; }
  .adv-desc { color: var(--ink-soft); }
</style>
