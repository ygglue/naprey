---
import { story } from '../data/content';

// Split the narrative so the pull-quote lands mid-story for editorial rhythm.
const [first, second, ...rest] = story.paragraphs;
---

<section id="story" class="section" aria-labelledby="story-heading">
  <div class="container">
    <header class="story-head" data-reveal>
      <span class="kicker">Background</span>
    </header>

    <h2 id="story-heading" class="story-title" data-reveal>{story.heading}</h2>

    <div class="story-body">
      <p class="story-lead" data-reveal>{first}</p>
      <p data-reveal>{second}</p>

      <blockquote class="pull" data-reveal>
        <p>{story.pullQuote}</p>
      </blockquote>

      {rest.map((para) => <p data-reveal>{para}</p>)}
    </div>
  </div>
</section>

<style>
  .story-head {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin-bottom: var(--space-sm);
  }
  .story-title { margin-bottom: var(--space-lg); }

  .story-body p {
    color: var(--ink-soft);
  }
  .story-lead {
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--ink);
  }

  /* Pull-quote — top/bottom rules + hanging quote, no left-stripe */
  .pull {
    margin-block: var(--space-xl);
    padding-block: var(--space-lg);
    border-block: 1px solid var(--line);
    max-width: none;
  }
  .pull p {
    position: relative;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-xl);
    line-height: 1.32;
    color: var(--ink);
    max-width: 30ch;
    padding-left: clamp(2rem, 1rem + 3vw, 3.25rem);
  }
  .pull p::before {
    content: '\201C';
    position: absolute;
    left: -0.15rem;
    top: -0.35em;
    font-style: normal;
    font-size: clamp(3.5rem, 2rem + 6vw, 5.5rem);
    line-height: 1;
    color: var(--accent);
    opacity: 0.3;
  }
</style>
