---
import { contact } from '../data/content';
import { ghl, ghlReady } from '../data/ghl';
---

<section id="contact" class="section" aria-labelledby="contact-heading">
  <div class="container">
    <header class="contact-head" data-reveal>
      <span class="kicker">Connect</span>
      <h2 id="contact-heading">{contact.heading}</h2>
      <p class="contact-intro">{contact.intro}</p>
    </header>

    <div class="contact-grid">
      <!-- GHL contact form or fallback -->
      <div class="contact-col" data-reveal>
        <h3>Send a message</h3>
        {ghlReady.form ? (
          <iframe
            src={ghl.formUrl}
            title="Contact form — send Naprey a message"
            class="ghl-frame ghl-form-frame"
            loading="lazy"
            sandbox="allow-scripts allow-forms allow-same-origin allow-popups"
            aria-label="GoHighLevel contact form"
          ></iframe>
        ) : (
          <div class="ghl-placeholder" role="region" aria-label="Contact form — pending setup">
            <p class="ghl-placeholder-msg">
              The contact form will appear here once the GoHighLevel account is connected.
              In the meantime, reach Naprey directly:
            </p>
            <ul class="contact-email-list" role="list">
              {contact.emails.map((e) => (
                <li>
                  <span class="contact-email-label">{e.label}</span>
                  <a href={`mailto:${e.address}`} class="contact-email-link">{e.address}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- GHL calendar or fallback -->
      <div class="contact-col" data-reveal>
        <h3>Book a consultation</h3>
        {ghlReady.calendar ? (
          <iframe
            src={ghl.calendarUrl}
            title="Booking calendar — schedule a consultation with Naprey Almario"
            class="ghl-frame ghl-calendar-frame"
            loading="lazy"
            sandbox="allow-scripts allow-forms allow-same-origin allow-popups"
            aria-label="GoHighLevel booking calendar"
          ></iframe>
        ) : (
          <div class="ghl-placeholder" role="region" aria-label="Booking calendar — pending setup">
            <p class="ghl-placeholder-msg">
              Online booking will be available here once the GoHighLevel calendar is connected.
              To schedule a call or meeting, email Naprey directly.
            </p>
          </div>
        )}
      </div>
    </div>

    <!-- Always-visible contact details -->
    <div class="contact-details" aria-label="Contact details" data-reveal>
      <dl class="contact-dl">
        <div class="contact-dl-item">
          <dt>Phone</dt>
          <dd><a href={`tel:${contact.phone.tel}`}>{contact.phone.display}</a></dd>
        </div>
        <div class="contact-dl-item">
          <dt>Email</dt>
          <dd>
            <ul class="contact-inline" role="list">
              {contact.emails.map((e) => (
                <li><a href={`mailto:${e.address}`}>{e.address}</a></li>
              ))}
            </ul>
          </dd>
        </div>
        <div class="contact-dl-item">
          <dt>Location</dt>
          <dd>{contact.location}</dd>
        </div>
        <div class="contact-dl-item">
          <dt>Social</dt>
          <dd>
            <ul class="contact-inline" role="list">
              {contact.social.map((s) => (
                <li>
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${s.platform}: ${s.label} (opens in new tab)`}
                  >{s.platform} — {s.label}</a>
                </li>
              ))}
            </ul>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .contact-head { margin-bottom: var(--space-xl); max-width: 60ch; }
  .contact-head h2 {
    font-size: var(--text-2xl);
    margin-block: var(--space-xs) var(--space-md);
  }
  .contact-intro {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
  .contact-col h3 {
    font-size: var(--text-md);
    margin-bottom: var(--space-sm);
  }

  @media (max-width: 700px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  /* GHL iframes */
  .ghl-frame {
    width: 100%;
    border: none;
    border-radius: 12px;
    display: block;
  }
  .ghl-form-frame { min-height: 520px; }
  .ghl-calendar-frame { min-height: 700px; }
  @media (max-width: 640px) {
    .ghl-form-frame { min-height: 400px; }
    .ghl-calendar-frame { min-height: 500px; }
  }

  .ghl-placeholder {
    padding: var(--space-md);
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    min-height: 200px;
  }
  .ghl-placeholder-msg {
    color: var(--ink-soft);
    margin-bottom: var(--space-sm);
  }
  .contact-email-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .contact-email-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink-soft);
  }

  .contact-details {
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }
  .contact-dl {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(200px, 100%), 1fr));
    gap: var(--space-md);
  }
  .contact-dl-item dt {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.4rem;
  }
  .contact-dl-item dd {
    color: var(--ink);
    font-size: var(--text-base);
  }
  .contact-inline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
</style>
