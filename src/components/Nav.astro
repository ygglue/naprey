---
import { nav, hero } from '../data/content';
---

<header class="site-header" role="banner">
  <div class="nav-inner container">
    <a href="#main-content" class="nav-brand" aria-label={`${hero.name} — top of page`}>
      {hero.name}
    </a>

    <nav class="nav-primary" aria-label="Primary navigation">
      <ul id="nav-menu" class="nav-links" role="list">
        {nav.links.map((link) => (
          <li><a href={link.href} class="nav-link">{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <a href={hero.cta.href} class="btn btn-primary nav-cta">{hero.cta.label}</a>
      <button
        type="button"
        class="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span class="nav-toggle-bars" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: color-mix(in srgb, var(--paper) 90%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    min-height: var(--nav-h);
    padding-block: 0.5rem;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1;
    color: var(--ink);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .nav-brand:hover { color: var(--accent-deep); }

  .nav-primary { margin-inline-start: auto; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.7rem;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--ink-soft);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--accent-deep);
    background-color: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .nav-cta {
    min-height: 44px;
    padding: 0.5rem 1.1rem;
    font-size: var(--text-sm);
    font-weight: 800;
  }

  /* Hamburger — hidden on desktop */
  .nav-toggle {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 8px;
    cursor: pointer;
  }
  .nav-toggle-bars,
  .nav-toggle-bars::before,
  .nav-toggle-bars::after {
    content: '';
    display: block;
    width: 20px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-toggle-bars { position: relative; }
  .nav-toggle-bars::before { position: absolute; top: -6px; left: 0; }
  .nav-toggle-bars::after  { position: absolute; top: 6px;  left: 0; }

  /* ── Collapse to hamburger + dropdown on smaller screens ── */
  @media (max-width: 880px) {
    .site-header { position: sticky; }
    .nav-toggle { display: inline-flex; }

    .nav-primary { margin-inline-start: 0; }
    .nav-actions { margin-inline-start: auto; }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.5rem clamp(1.1rem, 0.5rem + 3vw, 3rem) 1rem;
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-md);
      /* hidden until opened — kept out of the a11y tree & tab order */
      display: none;
    }
    .site-header.nav-open .nav-links { display: flex; }

    .nav-link {
      min-height: 48px;
      padding: 0.6rem 0.75rem;
      font-size: var(--text-base);
      border-radius: 8px;
    }

    /* morph bars → X when open */
    .site-header.nav-open .nav-toggle-bars { background: transparent; }
    .site-header.nav-open .nav-toggle-bars::before { transform: translateY(6px) rotate(45deg); }
    .site-header.nav-open .nav-toggle-bars::after  { transform: translateY(-6px) rotate(-45deg); }
  }

  @media (max-width: 420px) {
    .nav-brand { font-size: 1.35rem; }
    .nav-cta { padding: 0.5rem 0.85rem; }
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('nav-menu');

  if (header && toggle && menu) {
    const setOpen = (open: boolean) => {
      header.classList.toggle('nav-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };

    toggle.addEventListener('click', () =>
      setOpen(!header.classList.contains('nav-open'))
    );

    // Tapping a link navigates to the section — close the menu.
    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });

    // Escape closes and returns focus to the toggle.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.classList.contains('nav-open')) {
        setOpen(false);
        toggle.focus();
      }
    });

    // Click/tap outside the header closes it.
    document.addEventListener('click', (e) => {
      if (
        header.classList.contains('nav-open') &&
        !(e.target as HTMLElement).closest('.site-header')
      ) {
        setOpen(false);
      }
    });

    // Returning to desktop width forces the menu closed so state can't stick.
    window.matchMedia('(min-width: 881px)').addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });
  }
</script>
