---
import { updates } from '../data/content';
---

<section id="updates" class="section" aria-labelledby="updates-heading">
  <div class="container container--narrow">
    <header class="upd-head" data-reveal>
      <span class="kicker">{updates.kicker}</span>
      <h2 id="updates-heading">{updates.heading}</h2>
    </header>

    <ul class="upd-list" role="list">
      {updates.items.map((item) => (
        <li class="upd-item" data-reveal>
          <span class="upd-date">{item.date}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .upd-head { margin-bottom: var(--space-xl); }
  .upd-head h2 { margin-top: var(--space-xs); }

  .upd-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .upd-item {
    padding-block: var(--space-lg);
    border-bottom: 1px solid var(--line);
  }
  .upd-date {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent-deep);
    margin-bottom: 0.3rem;
  }
  .upd-item h3 { margin-bottom: 0.3rem; }
  .upd-item p { color: var(--ink-soft); }
</style>
